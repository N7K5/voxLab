# Copy to .env, or copy server/config.example.json to server/config.local.json.
# DATABASE_URL takes priority over the individual DB_* values.
DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_NAME=voxlab
DB_USER=
DB_PASSWORD=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

PORT=8787
SESSION_SECRET=change-this-in-production
ALLOWED_ORIGINS=http://localhost:5173
TRUST_PROXY=false
OLLAMA_ENDPOINT=http://localhost:11434
ALLOW_UNAUTHENTICATED_OLLAMA=false
